
{
    "openapi": "3.1.0",
    "info":{
        "title": "TP API Bibliothèque 2444332",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:3000/",
            "description": "Serveur de développement"
        },
        {
            "url": "à venir",
            "description": "Serveur render en ligne"
        }
    ],
    "paths": {
        "/api": {
            "get": {
                "summary": "Message de bienvenue",
                "tags": ["Accueil"],
                "responses": {
                    "200": {
                        "description": "Retourne un message de bienvenue",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Bienvenue à l'API de prêts de bibliothèque!"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/bibliotheque/livre": {
            "get": {
                "summary": "Récupère une liste de livres.",
                "security": [
                    {
                        "CleApiAuth": []
                    }
                ],
                "tags": ["Livres"],
                "description": "Récupère une liste de livres, pour une bibliothèque particulière avec sa clé d'api, en fonction de si ils sont disponibles.",
                "parameters": [
                    {
                        "in": "query",
                        "name": "tous",
                        "description": "Pour afficher tous les livres et non seulement les livres disponibles.",
                        "schema": {
                            "type": "boolean",
                            "example" : true
                        },
                        "required": false
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Liste de livres récupérée avec succès.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "id": {
                                                "type": "integer",
                                                "example": 3
                                            },
                                            "bibliotheque_id": {
                                                "type": "integer",
                                                "example": 2
                                            },
                                            "titre": {
                                                "type": "string",
                                                "example": "Raconte-moi Carey Price"
                                            },
                                            "auteur": {
                                                "type": "string",
                                                "example": "Jean-François Chaumont"
                                            },
                                            "isbn": {
                                                "type": "string", 
                                                "example": "9782924025949"
                                            },
                                            "date_ajout": { 
                                                "type": "string",
                                                "example": "2015-03-05T05:00:00.000Z"
                                            },
                                            "disponible": {
                                                "type": "boolean",
                                                "example": true
                                            },
                                            "description": {
                                                "type": "string",
                                                "example": "139 pages : illustrations ; 19 cm"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Clé API manquante ou invalide.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": { 
                                            "type": "string", 
                                            "example": "Vous devez fournir une clé api" 
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Erreur server",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "erreur": {
                                            "type": "string",
                                            "example": "Echec lors de la récupération de la liste des livres"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "summary": "Ajouter un livre.",
                "security": [
                    {
                        "CleApiAuth": []
                    }
                ],
                "tags": ["Livres"],
                "description": "Ajouter un livre pour une bibliothèque particulière avec sa clé d'api.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["titre", "auteur", "isbn", "disponible"],
                                "properties": {
                                    "titre": {
                                        "type": "string",
                                        "example": "Martine à la plage"
                                    },
                                    "auteur": {
                                        "type": "string",
                                        "example": "Félix Beauchesne"
                                    },
                                    "isbn": {
                                        "type": "string",
                                        "example": "123456"
                                    },
                                    "disponible": {
                                        "type": "boolean",
                                        "example": true
                                    },
                                    "date_ajout": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2007-05-02",
                                        "description": "Optionnel. Date d'ajout du livre (YYYY-MM-DD)."
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "L'histoire passionnante d'une prof de math.",
                                        "description": "Optionnel. Une courte description du livre."
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Livre ajouté avec succès",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Le livre [titre du livre] a été ajouté avec succès"
                                        },
                                        "livre": {
                                            "type": "object",
                                            "properties": {
                                                "id": {
                                                    "type": "integer",
                                                    "format": "int32",
                                                    "example": 9
                                                },
                                                "bibliotheque_id": {
                                                    "type": "integer",
                                                    "format": "int32",
                                                    "example": 1
                                                },
                                                "titre": {
                                                    "type": "string",
                                                    "example": "Martine à la plage"
                                                },
                                                "auteur": {
                                                    "type": "string",
                                                    "example": "Félix Beauchesne"
                                                },
                                                "isbn": {
                                                    "type": "string",
                                                    "example": "123456"
                                                },
                                                "date_ajout": {
                                                    "type": "string",
                                                    "format": "date",
                                                    "example": "2007-05-02"
                                                },
                                                "disponible": {
                                                    "type": "boolean",
                                                    "example": true
                                                },
                                                "description": {
                                                    "type": "string",
                                                    "example": "L'histoire passionnante d'une prof de math."
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Erreur de paramètres manquants",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "erreur": {
                                            "type": "string",
                                            "example": "Le format des données est invalide"
                                        },
                                        "champs_manquants": {
                                            "type": "array",
                                            "items": {
                                                "type": "string"
                                            },
                                            "example": ["disponible"]
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "500" : {
                        "description": "Erreur serveur",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "erreur": {
                                            "type": "string",
                                            "example": "Echec lors de la création du livre [titre du livre]"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/bibliotheque/livre/{id}": {
            "get": {
                "summary": "Récupérer les détails d'un livre.",
                "security": [
                    {
                        "CleApiAuth": []
                    }
                ],
                "tags": ["Livres"],
                "description": "Récupérer un livre en fonction de son ID.",
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "description": "ID du livre",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Livre retrouvé avec succès",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "titre": {
                                            "type": "string",
                                            "example": "Walking dead. 32, La fin du voyage"
                                        },
                                        "auteur":{
                                            "type": "string",
                                            "example": "Robert Kirkman"
                                        },
                                        "isbn": {
                                            "type": "string",
                                            "example": "9782413016816"
                                        },
                                        "disponible": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "description": {
                                            "type": "string",
                                            "example": "149 pages : principalement des illustrations (certaines en couleur) ; 26 cm"
                                        },
                                        "prets": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "id": {
                                                        "type": "integer",
                                                        "format": "int32",
                                                        "example": 1
                                                    },
                                                    "livre_id": {
                                                        "type": "integer",
                                                        "format": "int32",
                                                        "example": 1
                                                    },
                                                    "emprunteur": {
                                                        "type": "string",
                                                        "example": "Jean Dupont"
                                                    },
                                                    "date_debut": {
                                                        "type": "string",
                                                        "example": "2024-04-01T04:00:00.000Z"
                                                    },
                                                    "date_retour": {
                                                        "type": "string",
                                                        "example": "2024-05-01T04:00:00.000Z"
                                                    },
                                                    "date_retour_prevue": {
                                                        "type": "string",
                                                        "example": "2024-05-01T04:00:00.000Z"
                                                    },
                                                    "statut_pret": {
                                                        "type": "string",
                                                        "example": "Retourné"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Clé API manquante ou invalide.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": { 
                                            "type": "string", 
                                            "example": "Vous devez fournir une clé api" 
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Livre non trouvé.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "erreur": {
                                            "type": "string",
                                            "example": "Le livre avec l'id [id] n'existe pas pour cette bibliothèque"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "500":{
                        "description": "Erreur server",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "erreur": {
                                            "type": "string",
                                            "example": "Echec lors de la récupération du livre avec l'id [id]"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "put": {
                "summary": "Modifier un livre.",
                "security": [
                    {
                        "CleApiAuth": []
                    }
                ],
                "tags": ["Livres"],
                "description": "Modifier un livre en fonction de son ID.",
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "description": "ID du livre",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "example": 1
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["titre", "auteur", "isbn", "disponible"],
                                "properties": {
                                    "titre": {
                                        "type": "string",
                                        "example": "Le Canadien face au bêtes sauvages"
                                    },
                                    "auteur": {
                                        "type": "string",
                                        "example": "Martin Matte"
                                    },
                                    "isbn": {
                                        "type": "string",
                                        "example": "987654321"
                                    },
                                    "disponible": {
                                        "type": "boolean",
                                        "example": true
                                    },
                                    "date_ajout": {
                                        "type": "integer",
                                        "example": "2026-05-06",
                                        "nullable": true
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Les buffalos vont faire face aux jeunes Canadiens en bleu et rouge.",
                                        "nullable": true
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Livre modifié avec succès",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Le livre à l'ID [id] a été modifié avec succès"
                                        }
                                    }
                                }   
                            }
                        }
                    },
                    "400" : {
                        "description": "Erreur de paramètres manquants",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "erreur": {
                                            "type": "string",
                                            "example": "Le format des données est invalide"
                                        },
                                        "champs_manquants": {
                                            "type": "array",
                                            "items": {
                                                "type": "string"
                                            },
                                            "example": ["titre", "auteur"]
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Clé API manquante ou invalide.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": { 
                                            "type": "string", 
                                            "example": "Vous devez fournir une clé api" 
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404" : {
                        "description": "Livre non rencontré",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "erreur": {
                                            "type": "string",
                                            "example": "Le livre à l'ID [id] n'existe pas pour cette bibliothèque dans la base de données"
                                        }
                                    }
                                }   
                            }
                        }
                    },
                    "500" : {
                        "description": "Livre non modifié",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "erreur": {
                                            "type": "string",
                                            "example": "Echec lors de la modification du livre [titre du livre]"
                                        }
                                    }
                                }   
                            }
                        }
                    }
                }
            }
        },
        "/api/bibliotheque/livre/{id}/status": {
            "put": {
                "summary": "Modifier le status d'un livre.",
                "security": [
                    {
                        "CleApiAuth": []
                    }
                ],
                "tags": ["Livres"],
                "description": "Modifier le status d'un livre en fonction de son ID.",
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "description": "ID du livre",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "example": 1
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["disponible"],
                                "properties": {
                                    "disponible": {
                                        "type": "boolean",
                                        "example": true
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Status du livre modifié avec succès",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Le status du libre à l'ID [id] a été modifié avec succès"
                                        }
                                    }
                                }   
                            }
                        }
                    },
                    "400" : {
                        "description": "Erreur de paramètres manquants",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "erreur": {
                                            "type": "string",
                                            "example": "Le champ disponible est invalide"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Clé API manquante ou invalide.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": { 
                                            "type": "string", 
                                            "example": "Vous devez fournir une clé api" 
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404" : {
                        "description": "Livre non rencontré",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "erreur": {
                                            "type": "string",
                                            "example": "Le livre à l'ID [id] n'existe pas pour cette bibliothèque dans la base de données"
                                        }
                                    }
                                }   
                            }
                        }
                    },
                    "500" : {
                        "description": "Status du livre non modifié",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "erreur": {
                                            "type": "string",
                                            "example": "Echec lors de la modification du status du livre [id]"
                                        }
                                    }
                                }   
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "CleApiAuth": {
                "type": "apiKey",
                "in": "header",
                "name": "Authorization",
                "description": "Veuillez entrer votre clé sous le format : cle_api XXXXXX"
            }
        }
    }
}